algoritmo "Função SE e E"
// Função :
// Autor :
// Data : 22/02/2026
// Seção de Declarações 
var
numero:inteiro

inicio


      Escreval ("Digite um número até os decimais:")
      leia(numero)
      
      Se (numero >=2) e (numero <=10 ) Entao
      Escreval ("Número satisfaz o intervalo")
       Senao
       Escreval("Número não satisfaz a equação")
       FimSe


fimalgoritmo
