algoritmo "VAR repita"
// Funçăo :
// Autor :
// Data : 21/03/2026
// até a expressăo boleana for verdadeira
// <instruçăo a serem executadas rapidamente até a expresssăo boleana for verdadeira >
var
letra: caractere
inicio
      repita

      escreval ("Digite uma letra:")
      leia (letra)
      
      ate letra = "a"
      
      escreval ("muito bem vocę digitou a letra A")
fimalgoritmo
