algoritmo "funçăo SE"
// Funçăo :
// Autor :
// Data : 18/02/2026
// Seçăo de Declaraçőes 
var

   numero : INTEIRO
   
inicio

Escreval("escreva um numero :")
leia (numero)
      Se (numero>10) Entao
       Escreval (numero,"numero maior que dez, que peninha...")
       Senao
       Escreval (numero,"numero,é menor que dez, jackpot!")



fimalgoritmo

