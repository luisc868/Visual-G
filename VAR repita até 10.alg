algoritmo "VAR repita até 10"
// Função :
// Autor :
// Data : 21/03/2026
// até a expressão boleana for verdadeira
// <instrução a serem executadas rapidamente até a expresssão boleana for verdadeira >
var
numero: inteiro
inicio

      numero <- 0

      repita

       numero <- numero + 1
       escreval (numero)
      
      ate numero >= 10
      

fimalgoritmo
