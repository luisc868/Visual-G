algoritmo "Função SE e OU "
// Função :
// Autor :
// Data : 22/02/2026
// Seção de Declarações 
var

cor: caractere

inicio


      Escreva ("digite uma cor:")
      Leia(cor )

      Se (cor="amarelo") ou (cor="azul") entao
      Escreval  ("A cor digitada é azul ou amarelo")
      
      Senao
      Escreval("Cor nao presente no sistema")
      
      FimSe
      fimalgoritmo


