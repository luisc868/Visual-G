algoritmo "LAN HOUSE"
// Funçăo :
// Autor :
// Data : 18/02/2026
// Seçăo de Declaraçőes 
var
 minutos, totalApagar : real
 
inicio

      Escreval("Digite a quantidade de minutos utilizada pelo cliente:")
    Leia(minutos)
    
    totalApagar<- minutos * ((1/60)*2)
    
     escreval ("total a pagar:",totalApagar, "reais")
    
    
fimalgoritmo
