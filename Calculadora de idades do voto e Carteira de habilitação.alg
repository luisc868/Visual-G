algoritmo "Calculadora de idades do voto e Carteira de habilitaçăo"
// Funçăo :
// Autor :
// Data : 22/02/2026
// Seçăo de Declaraçőes 
var
anoDeNascimento:inteiro
idade:inteiro
nome: caractere
inicio
       Escreval ("Digite o nome do votante: ")
       leia (nome)
       
      Escreval ("Digite o ano de nascimento :")
      Leia (anoDeNascimento)
       idade <- ( 2026 - anoDeNascimento)

       Se (idade >= 18) Entao

       Escreval (nome,"," , idade , " Disponível para votar e tirar a carta de habilitçăo ")

       Senao

       Se (idade >= 16) Entao

       Escreval (nome,"," , idade , " Disponível para votar e indisponível para a carta de habilitçăo ")
       Senao
       Escreval (nome,"," , idade , " indisponível para votar e indisponível para a carta de habilitçăo ")
       FimSe
       FimSe
       fimalgoritmo


