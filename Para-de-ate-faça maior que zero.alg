algoritmo "Para-de-ate-faça maior que zero"
// Função :
// Autor :
// Data : 15/03/2026
// Seção de Declarações 
var
 numero: inteiro
inicio

      escreval ("Digite um numero maior que zero:")
      Leia (numero)
      
para numero de 0  ate numero  faca
escreval ("numero", numero)



fimPara
fimalgoritmo
